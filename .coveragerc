# Cấu hình cho coverage.py — chỉ đo code trong app/.
# Không đo:
#   - tests/        (đo test không có ý nghĩa)
#   - migrations/   (auto-gen)
#   - scripts/      (one-off CLI)
[run]
source =
    app
branch = True

omit =
    app/__init__.py
    app/cli.py
    app/extensions.py
    app/config.py
    */migrations/*
    */__pycache__/*
    */.venv/*
    */scripts/*
    */tests/*

[report]
show_missing = True
skip_covered = False
precision = 2
sort = -Cover
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    def __repr__
    if TYPE_CHECKING: