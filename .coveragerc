# Chỉ đo coverage cho app/services/.
# Tất cả phần còn lại (api/, models/, repositories/, middleware/, ...) bị
# exclude để SonarCloud Quality Gate không fail vì coverage thấp ở chỗ
# ít quan trọng, đồng thời số liệu chỉ phản ánh code business logic.
[run]
source =
    app/services

branch = True

# Không đo thư mục KHÔNG PHẢI services/ — những chỗ này là wiring/ORM/transport.
omit =
    app/__init__.py
    app/cli.py
    app/extensions.py
    app/config.py
    app/api/*
    app/models/*
    app/repositories/*
    app/middleware/*
    app/common/*
    app/errors/*
    app/i18n/*
    app/__pycache__/*
    */__pycache__/*
    */.venv/*
    */tests/*

[report]
show_missing = True
skip_covered = False
precision = 2
sort = -Cover
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    def __repr__
    if TYPE_CHECKING:
