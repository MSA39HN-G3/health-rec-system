# Sao chép file này thành .env và điền giá trị thật. KHÔNG commit file .env.
# Copy this file to .env and fill in real values. DO NOT commit the .env file.

# Môi trường chạy: development | production | testing
FLASK_ENV=development

# Khóa bí mật cho session/ký token. Bắt buộc đổi ở môi trường production.
SECRET_KEY=change-me-to-a-long-random-string

# Chuỗi kết nối database (SQLAlchemy URL) - PostgreSQL 16, driver psycopg (v3).
# Định dạng: postgresql+psycopg://user:password@host:port/database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/health_rec

# Ngôn ngữ mặc định khi không xác định được từ request: en | vi
DEFAULT_LOCALE=vi

# ----- JWT (token phiên hệ thống cấp sau khi đăng nhập) -----
# Khóa ký JWT. Mặc định dùng chung SECRET_KEY nếu để trống.
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
# Thời gian sống access token (giây). 3600 = 1 giờ.
JWT_EXPIRES=3600

# Google OAuth2 - lấy từ Google Cloud Console > APIs & Services > Credentials
# (tạo OAuth client ID dạng "Web application").
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Phải khớp TUYỆT ĐỐI với "Authorized redirect URI" khai báo trên Google Console.
# Đây là URL trang FE xử lý callback (nơi Google trả authorization_code về).
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# Scope mặc định để lấy thông tin cơ bản (giữ nguyên nếu không có nhu cầu đặc biệt).
GOOGLE_OAUTH_SCOPES=openid email profile
# Thời gian sống của `state` chống CSRF (giây). Mặc định 600 = 10 phút.
GOOGLE_OAUTH_STATE_TTL=600

# ----- CORS (middleware cho FE khác origin) -----
# Danh sách origin FE được phép gọi API, phân tách bằng dấu phẩy. "*" = mọi origin (chỉ dev).
CORS_ORIGINS=http://localhost:3000
# Cho phép gửi cookie/credential kèm request: true | false
CORS_SUPPORTS_CREDENTIALS=true

# ----- Rate limit (Token Bucket, theo IP + endpoint) -----
# Bật/tắt giới hạn: true | false
RATELIMIT_ENABLED=true
# Sức chứa giỏ token = số request burst tối đa tức thời.
RATELIMIT_CAPACITY=120
# Tốc độ hồi token (token/giây) = tốc độ request ổn định. 2.0 ~ 120 request/phút.
RATELIMIT_REFILL_RATE=2.0

# ----- Logging -----
# Mức log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Các path KHÔNG ghi log truy cập (tách bằng dấu phẩy).
LOG_SKIP_PATHS=/health

# ----- Cloudflare R2 (lưu object, S3-compatible) -----
# Lấy từ Cloudflare Dashboard > R2 > "Manage R2 API Tokens".
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
# Tên bucket đã tạo trong R2.
R2_BUCKET=health-rec-assets
# Optional: custom domain trỏ vào bucket (vd assets.example.com). Để trống nếu
# dùng domain mặc định của R2 <accountid>.r2.cloudflarestorage.com.
# Lưu ý: URL public này chỉ hoạt động khi bucket được bật "Public Development Access".
# Nếu bucket PRIVATE (mặc định trong hệ thống này) thì FE chỉ xem được qua presigned GET.
R2_PUBLIC_HOST=
# Thời gian sống (giây) của presigned URL PUT (FE upload) và GET (FE xem ảnh).
R2_PRESIGN_PUT_TTL=600
R2_PRESIGN_GET_TTL=3600
# Giới hạn upload (bytes). Mặc định 15MB.
R2_MAX_UPLOAD_BYTES=15728640
# Danh sách content type được phép upload (tách bằng dấu phẩy).
R2_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,application/pdf
