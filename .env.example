# Sao chép file này thành .env và điền giá trị thật. KHÔNG commit file .env.
# Copy this file to .env and fill in real values. DO NOT commit the .env file.

# Môi trường chạy: development | production | testing
FLASK_ENV=development

# Khóa bí mật cho session/ký token. Bắt buộc đổi ở môi trường production.
SECRET_KEY=change-me-to-a-long-random-string

# Chuỗi kết nối database (SQLAlchemy URL) - PostgreSQL 16, driver psycopg (v3).
# Định dạng: postgresql+psycopg://user:password@host:port/database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/health_rec

# Ngôn ngữ mặc định khi không xác định được từ request: en | vi
DEFAULT_LOCALE=vi

# Google OAuth2 - lấy từ Google Cloud Console > APIs & Services > Credentials
# (tạo OAuth client ID dạng "Web application").
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Phải khớp TUYỆT ĐỐI với "Authorized redirect URI" khai báo trên Google Console.
# Đây là URL trang FE xử lý callback (nơi Google trả authorization_code về).
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# Scope mặc định để lấy thông tin cơ bản (giữ nguyên nếu không có nhu cầu đặc biệt).
GOOGLE_OAUTH_SCOPES=openid email profile
